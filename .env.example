# Database (required for production — omit to use in-memory mock store for dev)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Auth (required — NextAuth 5 beta does NOT auto-generate a secret)
NEXTAUTH_SECRET=generate-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI (optional — categorization and insights degrade gracefully without this)
OPENAI_API_KEY=sk-...

# Payments (optional — billing page shows setup instructions without these)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Bank Connections via Plaid (optional — settings page shows setup instructions without these)
PLAID_CLIENT_ID=...
PLAID_SECRET=...
PLAID_ENCRYPTION_KEY=generate-a-random-32-char-string

# Email (optional — email verification and reminders are auto-bypassed without these)
RESEND_API_KEY=re_...
# OR
SENDGRID_API_KEY=SG...
EMAIL_FROM=noreply@ledgr.com
